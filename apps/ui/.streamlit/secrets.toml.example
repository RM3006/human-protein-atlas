# Copy to apps/ui/.streamlit/secrets.toml (gitignored) for local runs, or set these
# in the Streamlit Community Cloud "Secrets" UI when deploying.
# The app also falls back to environment variables of the same names.
MOTHERDUCK_TOKEN = "your-motherduck-token"
QDRANT_URL = "https://your-cluster.qdrant.io"
QDRANT_API_KEY = "your-qdrant-api-key"
